{
  "name": "fauxbase-svelte",
  "version": "0.5.8",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "svelte": ">=4",
    "fauxbase": ">=0.5.0"
  },
  "devDependencies": {
    "svelte": "^4.2.0",
    "fauxbase": "workspace:*",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
